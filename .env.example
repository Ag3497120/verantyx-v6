# Apple Music API proxy (Cloudflare Pages Functions)
# Copy to .dev.vars for local `wrangler pages dev` — never commit real secrets.
# PEM: keep newlines as \n in a single line, or paste multiline in the CF dashboard.

APPLE_TEAM_ID=XXXXXXXXXX
APPLE_MUSIC_KEY_ID=XXXXXXXXXX
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Comma-separated keys for friends / apps calling the proxy
FRIEND_API_KEYS=friend-key-one,friend-key-two

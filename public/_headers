# HTML must revalidate so deploys are not stuck behind long edge TTLs.
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashed Next assets can be cached aggressively.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
